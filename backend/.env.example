# Database
DATABASE_URL=postgres://ghostbounty:ghostbounty@localhost:5432/ghostbounty

# Ethereum RPC
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# WebSocket RPC (optional — auto-derived from RPC_URL if not set)
# WS_RPC_URL=wss://sepolia.infura.io/ws/v3/YOUR_INFURA_KEY

# GhostBounty contract
CONTRACT_ADDRESS=0x15eF2AF4A8553f49c19C397788c4d5a7e2220a59

# Block to start indexing from (contract deployment block)
DEPLOY_BLOCK=10438838

# Historical sync batch size
BATCH_SIZE=10000

# API
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
NODE_ENV=development
